{
  "name": "clmm-autopilot-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "collect:price": "tsx scripts/collectors/jupiter-price.ts",
    "collect:backend": "tsx scripts/collectors/backend-snapshot.ts",
    "insight:daily": "tsx scripts/generate/daily-insight.ts",
    "review:range": "tsx scripts/generate/range-review.ts",
    "review:weekly": "tsx scripts/generate/weekly-review.ts",
    "cron:render": "tsx scripts/openclaw/render-cron-commands.ts",
    "cron:sync": "tsx scripts/openclaw/sync-cron.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "boundaries": "depcruise --config .dependency-cruiser.cjs src",
    "verify": "pnpm typecheck && pnpm test && pnpm boundaries"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.10.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
