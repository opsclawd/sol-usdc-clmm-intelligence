{
  "name": "clmm-autopilot-pipeline",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "collect:price": "tsx scripts/collectors/jupiter-price.ts",
    "collect:clmm-bundle": "tsx scripts/collectors/clmm-bundle.ts",
    "collect:core": "tsx scripts/collectors/core-collection.ts",
    "cron:render": "tsx scripts/openclaw/render-cron-commands.ts",
    "cron:sync": "tsx scripts/openclaw/sync-cron.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "format": "prettier --check .",
    "boundaries": "depcruise --config .dependency-cruiser.cjs src",
    "verify": "pnpm typecheck && pnpm lint && pnpm format && pnpm test && pnpm boundaries",
    "prepare": "husky || true",
    "db:generate": "drizzle-kit generate",
    "db:provision-roles": "tsx scripts/db-provision-roles.ts",
    "db:migrate": "tsx scripts/db-ensure-schema.ts && drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.9",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dependency-cruiser": "^16.10.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
