      "checkConstraints": {
        "chk_features_signal_class": {
          "name": "chk_features_signal_class",
          "value": "\"intelligence\".\"derived_features\".\"signal_class\" IN ('deterministic', 'probabilistic', 'contextual')"
        },
        "chk_features_evidence_family": {
          "name": "chk_features_evidence_family",
          "value": "\"intelligence\".\"derived_features\".\"evidence_family\" IN ('clmm_state', 'price_quality', 'clmm_economics', 'execution_safety', 'market_regime', 'support_resistance', 'on_chain_flow', 'perp_liquidation', 'macro_protocol_risk')"
        },
        "chk_features_confidence_composite": {
          "name": "chk_features_confidence_composite",
          "value": "\"intelligence\".\"derived_features\".\"confidence_composite\" IS NULL OR (\"intelligence\".\"derived_features\".\"confidence_composite\" >= 0 AND \"intelligence\".\"derived_features\".\"confidence_composite\" <= 1)"
        },
        "chk_features_confidence_level": {
          "name": "chk_features_confidence_level",
          "value": "\"intelligence\".\"derived_features\".\"confidence_level\" IS NULL OR \"intelligence\".\"derived_features\".\"confidence_level\" IN ('low', 'medium', 'high')"
        },
        "chk_features_stale_behavior": {
          "name": "chk_features_stale_behavior",
          "value": "\"intelligence\".\"derived_features\".\"stale_behavior\" IS NULL OR \"intelligence\".\"derived_features\".\"stale_behavior\" IN ('exclude', 'degrade_confidence', 'allow_context_only')"
        },
        "chk_features_status": {
          "name": "chk_features_status",
          "value": "\"intelligence\".\"derived_features\".\"status\" IN ('AVAILABLE', 'PARTIAL', 'UNAVAILABLE')"
        },
        "chk_features_unit": {
          "name": "chk_features_unit",
          "value": "\"intelligence\".\"derived_features\".\"unit\" IN ('BPS', 'PPM')"
        },
        "chk_features_kind_allowlist": {
          "name": "chk_features_kind_allowlist",
          "value": "\"intelligence\".\"derived_features\".\"feature_kind\" IN ('range_location', 'distance_to_lower', 'distance_to_upper', 'oracle_dex_divergence', 'oracle_confidence_width', 'realized_volatility_1h', 'volume_liquidity_ratio_24h')"
        },
        "chk_features_status_value": {
          "name": "chk_features_status_value",
          "value": "((\"intelligence\".\"derived_features\".\"status\" = 'UNAVAILABLE' AND \"intelligence\".\"derived_features\".\"value\" IS NULL) OR (\"intelligence\".\"derived_features\".\"status\" <> 'UNAVAILABLE' AND \"intelligence\".\"derived_features\".\"value\" IS NOT NULL))"
        },
        "chk_features_unit_bps": {
          "name": "chk_features_unit_bps",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'oracle_dex_divergence' AND \"intelligence\".\"derived_features\".\"unit\" = 'BPS') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'oracle_dex_divergence'))"
        },
        "chk_features_unit_bps2": {
          "name": "chk_features_unit_bps2",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'oracle_confidence_width' AND \"intelligence\".\"derived_features\".\"unit\" = 'BPS') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'oracle_confidence_width'))"
        },
        "chk_features_unit_bps3": {
          "name": "chk_features_unit_bps3",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'realized_volatility_1h' AND \"intelligence\".\"derived_features\".\"unit\" = 'BPS') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'realized_volatility_1h'))"
        },
        "chk_features_unit_ppm": {
          "name": "chk_features_unit_ppm",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'range_location' AND \"intelligence\".\"derived_features\".\"unit\" = 'PPM') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'range_location'))"
        },
        "chk_features_unit_ppm2": {
          "name": "chk_features_unit_ppm2",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'distance_to_lower' AND \"intelligence\".\"derived_features\".\"unit\" = 'PPM') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'distance_to_lower'))"
        },
        "chk_features_unit_ppm3": {
          "name": "chk_features_unit_ppm3",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'distance_to_upper' AND \"intelligence\".\"derived_features\".\"unit\" = 'PPM') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'distance_to_upper'))"
        },
        "chk_features_unit_ppm4": {
          "name": "chk_features_unit_ppm4",
          "value": "((\"intelligence\".\"derived_features\".\"feature_kind\" = 'volume_liquidity_ratio_24h' AND \"intelligence\".\"derived_features\".\"unit\" = 'PPM') OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'volume_liquidity_ratio_24h'))"
        },
        "chk_features_scope_position": {
          "name": "chk_features_scope_position",
          "value": "(((\"intelligence\".\"derived_features\".\"feature_kind\" IN ('range_location', 'distance_to_lower', 'distance_to_upper')) AND \"intelligence\".\"derived_features\".\"pool_id\" IS NOT NULL AND \"intelligence\".\"derived_features\".\"position_id\" IS NOT NULL) OR (\"intelligence\".\"derived_features\".\"feature_kind\" NOT IN ('range_location', 'distance_to_lower', 'distance_to_upper')))"
        },
        "chk_features_scope_volume": {
          "name": "chk_features_scope_volume",
          "value": "(((\"intelligence\".\"derived_features\".\"feature_kind\" = 'volume_liquidity_ratio_24h') AND \"intelligence\".\"derived_features\".\"pool_id\" IS NOT NULL AND \"intelligence\".\"derived_features\".\"position_id\" IS NULL) OR (\"intelligence\".\"derived_features\".\"feature_kind\" <> 'volume_liquidity_ratio_24h'))"
        },
        "chk_features_scope_other": {
          "name": "chk_features_scope_other",
          "value": "(((\"intelligence\".\"derived_features\".\"feature_kind\" IN ('oracle_dex_divergence', 'oracle_confidence_width', 'realized_volatility_1h')) AND \"intelligence\".\"derived_features\".\"pool_id\" IS NULL AND \"intelligence\".\"derived_features\".\"position_id\" IS NULL) OR (\"intelligence\".\"derived_features\".\"feature_kind\" NOT IN ('oracle_dex_divergence', 'oracle_confidence_width', 'realized_volatility_1h')))"
        }
      },
      "isRLSEnabled": false
