# Backend that owns deterministic CLMM data/calculations.
CLMM_DATA_API_BASE=http://localhost:3001

# Optional API keys for collectors.
COINGECKO_API_KEY=
PERPLEXITY_API_KEY=

# Solana token mints.
SOL_MINT=So11111111111111111111111111111111111111112
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Pair and pool config.
PAIR=SOL/USDC
RAYDIUM_POOL_ID=
WALLET_PUBLIC_KEY=

# OpenClaw cron registration defaults.
OPENCLAW_MODEL=opus
OPENCLAW_THINKING=high
OPENCLAW_AGENT=
OPENCLAW_DELIVERY_CHANNEL=telegram
OPENCLAW_DELIVERY_TO=
OPENCLAW_EXACT=true

# Safety switch. Scripts refuse execution-mode actions unless false.
RECOMMENDATION_ONLY=true
