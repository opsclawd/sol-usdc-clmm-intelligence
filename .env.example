# Backend that owns deterministic CLMM data/calculations.
CLMM_DATA_API_BASE=http://localhost:3001
CLMM_INSIGHTS_API_KEY=

# Optional pipeline metadata. Set INTELLIGENCE_CODE_VERSION to the deployed commit SHA
# in production scheduling; local runs fall back to "development". These values are
# advisory only and are never stored in request metadata (API keys and headers are
# never persisted in sourceRequestMeta).
INTELLIGENCE_CODE_VERSION=development
INTELLIGENCE_PIPELINE_RUN_ID=

# Comma-separated list of position IDs for MVP feature derivation.
INTELLIGENCE_POSITION_IDS=

# Optional API keys for collectors.
COINGECKO_API_KEY=
PERPLEXITY_API_KEY=

# Pyth Hermes and Jupiter API configurations
PYTH_HERMES_BASE_URL=https://hermes.pyth.network
PYTH_API_KEY=
PYTH_SOL_USD_FEED_ID=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d
JUPITER_API_BASE=https://api.jup.ag
JUPITER_API_KEY=

# Orca API configuration
ORCA_API_BASE=https://api.orca.so/v2/solana
ORCA_SOL_USDC_WHIRLPOOL=HJPn8wAHkWZ25sfP45Rpggct383GCFU4e43Dmm4D97sw

# Solana token mints.
SOL_MINT=So11111111111111111111111111111111111111112
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Pair and pool config.
PAIR=SOL/USDC
RAYDIUM_POOL_ID=
WALLET_PUBLIC_KEY=

# OpenClaw cron registration defaults.
OPENCLAW_MODEL=opus
OPENCLAW_THINKING=high
OPENCLAW_AGENT=
OPENCLAW_DELIVERY_CHANNEL=telegram
OPENCLAW_DELIVERY_TO=
OPENCLAW_EXACT=true

# Safety switch. Scripts refuse execution-mode actions unless false.
RECOMMENDATION_ONLY=true

# --- Database (shared Railway Postgres, intelligence schema) ---
DATABASE_URL=postgres://user:pass@host:5432/db
PG_SSL=true
PG_MAX_CONNECTIONS=10
