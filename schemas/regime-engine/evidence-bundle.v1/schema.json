            "$ref": "#/$defs/identifier128"
          }
        },
        "provenanceMethod": {
          "enum": ["collected", "derived", "human_authored"]
        }
      }
    },
    "derivativesClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceId",
        "kind",
        "claim",
        "direction",
        "confidenceBps",
        "observedAt",
        "expiresAt",
        "sourceReferenceIds",
        "provenanceMethod"
      ],
      "properties": {
        "evidenceId": {
          "$ref": "#/$defs/identifier128"
        },
        "kind": {
          "enum": ["funding", "open_interest", "liquidation", "options_skew"]
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "direction": {
          "enum": ["bullish", "bearish", "neutral", "mixed", "unknown"]
        },
        "confidenceBps": {
          "$ref": "#/$defs/confidenceBps"
        },
        "observedAt": {
          "$ref": "#/$defs/canonicalTimestamp"
        },
        "expiresAt": {
          "anyOf": [{ "$ref": "#/$defs/canonicalTimestamp" }, { "type": "null" }]
        },
        "sourceReferenceIds": {
          "type": "array",
