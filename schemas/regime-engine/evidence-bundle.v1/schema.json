          }
        },
        "provenanceMethod": {
          "enum": ["collected", "derived", "human_authored"]
        }
      }
    },
    "contextualEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supportResistance", "flows", "derivatives", "events", "newsRegulatory"],
      "properties": {
        "supportResistance": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/supportResistanceClaim"
          }
        },
        "flows": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/flowClaim"
          }
        },
        "derivatives": {
          "type": "array",
          "maxItems": 64,
          "items": {
