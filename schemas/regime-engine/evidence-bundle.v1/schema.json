    "modelInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "modelId", "modelVersion"],
      "properties": {
        "provider": {
          "$ref": "#/$defs/identifier128"
        },
        "modelId": {
          "$ref": "#/$defs/identifier128"
        },
        "modelVersion": {
          "$ref": "#/$defs/identifier128"
        }
      }
    },
    "researchBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "briefId",
        "generatedAt",
        "summary",
        "keyFindings",
        "uncertainties",
        "model",
        "promptVersion",
        "sourceEvidenceIds"
      ],
      "properties": {
        "briefId": {
          "$ref": "#/$defs/identifier128"
        },
        "generatedAt": {
          "$ref": "#/$defs/canonicalTimestamp"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "keyFindings": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          }
        },
        "uncertainties": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          }
        },
        "model": {
          "$ref": "#/$defs/modelInfo"
        },
        "promptVersion": {
          "$ref": "#/$defs/identifier128"
        },
        "sourceEvidenceIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/identifier128"
          }
        }
      }
    },
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["referenceId", "sourceType", "locator", "observedAt"],
      "properties": {
        "referenceId": {
          "$ref": "#/$defs/identifier128"
        },
        "sourceType": {
          "enum": ["api", "database", "chain", "document", "internal_bundle"]
        },
        "locator": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "publishedAt": {
          "anyOf": [{ "$ref": "#/$defs/canonicalTimestamp" }, { "type": "null" }]
        },
        "observedAt": {
          "$ref": "#/$defs/canonicalTimestamp"
        },
        "contentHash": {
          "anyOf": [{ "$ref": "#/$defs/hex64" }, { "type": "null" }]
        }
      }
    },
    "coverageStatus": {
      "enum": ["available", "partial", "unavailable", "not_applicable"]
    },
    "familyCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deterministic",
        "supportResistance",
        "flows",
        "derivatives",
        "events",
        "newsRegulatory",
        "researchBrief"
      ],
      "properties": {
        "deterministic": {
          "$ref": "#/$defs/coverageStatus"
        },
        "supportResistance": {
          "$ref": "#/$defs/coverageStatus"
        },
        "flows": {
          "$ref": "#/$defs/coverageStatus"
        },
        "derivatives": {
          "$ref": "#/$defs/coverageStatus"
        },
        "events": {
          "$ref": "#/$defs/coverageStatus"
        },
        "newsRegulatory": {
          "$ref": "#/$defs/coverageStatus"
        },
        "researchBrief": {
          "$ref": "#/$defs/coverageStatus"
        }
      }
    },
    "bundleWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "affectedFamilies"],
      "properties": {
        "code": {
          "$ref": "#/$defs/identifier128"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "affectedFamilies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "qualityLevel": {
      "enum": ["complete", "partial", "degraded"]
    },
    "bundleAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overallConfidenceBps", "quality", "coverage", "warnings"],
      "properties": {
        "overallConfidenceBps": {
          "$ref": "#/$defs/confidenceBps"
        },
        "quality": {
          "$ref": "#/$defs/qualityLevel"
        },
        "coverage": {
          "$ref": "#/$defs/familyCoverage"
        },
        "warnings": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/bundleWarning"
          }
        }
      }
    },
    "bundleProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipelineVersion", "gitCommit", "environment", "upstreamRunIds"],
      "properties": {
        "pipelineVersion": {
          "$ref": "#/$defs/identifier128"
        },
        "gitCommit": {
          "$ref": "#/$defs/hex64"
        },
        "environment": {
          "enum": ["production", "staging", "development", "test"]
        },
        "upstreamRunIds": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/identifier128"
          }
        }
      }
    },
    "schemaVersion": {
      "const": "evidence-bundle.v1"
    },
    "pair": {
      "const": "SOL/USDC"
    }
  },
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/schemaVersion"
    },
    "pair": {
      "$ref": "#/$defs/pair"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "source": {
      "$ref": "#/$defs/sourceIdentity"
    },
    "runId": {
      "$ref": "#/$defs/identifier256"
    },
    "correlationId": {
      "$ref": "#/$defs/identifier256"
    },
    "createdAt": {
      "$ref": "#/$defs/canonicalTimestamp"
    },
    "asOf": {
      "$ref": "#/$defs/canonicalTimestamp"
    },
    "freshUntil": {
      "$ref": "#/$defs/canonicalTimestamp"
    },
    "expiresAt": {
      "$ref": "#/$defs/canonicalTimestamp"
    },
    "deterministicFeatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/deterministicFeature"
      }
    },
    "contextualEvidence": {
      "$ref": "#/$defs/contextualEvidence"
    },
    "researchBrief": {
      "anyOf": [{ "$ref": "#/$defs/researchBrief" }, { "type": "null" }]
    },
    "sourceReferences": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/sourceReference"
      }
    },
    "assessment": {
      "$ref": "#/$defs/bundleAssessment"
    },
    "provenance": {
      "$ref": "#/$defs/bundleProvenance"
    }
  }
}
