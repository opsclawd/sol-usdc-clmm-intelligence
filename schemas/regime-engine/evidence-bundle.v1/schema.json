        "kind",
        "claim",
        "direction",
        "confidenceBps",
        "observedAt",
        "expiresAt",
        "sourceReferenceIds",
        "provenanceMethod"
      ],
      "properties": {
        "evidenceId": {
          "$ref": "#/$defs/identifier128"
        },
        "kind": {
          "enum": ["ecosystem_news", "regulatory_update"]
        },
        "claim": {
          "type": "string",
          "minLength": 1,
