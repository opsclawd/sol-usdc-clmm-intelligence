        },
        "sourceReferenceIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/identifier128"
          }
        },
        "provenanceMethod": {
          "enum": ["collected", "derived", "human_authored"]
        }
