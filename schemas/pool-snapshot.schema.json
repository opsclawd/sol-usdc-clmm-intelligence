{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PoolSnapshot",
  "type": "object",
  "required": [
    "pair",
    "timestamp",
    "source"
  ],
  "properties": {
    "pair": {
      "const": "SOL/USDC"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "poolId": {
      "type": "string"
    },
    "spotPrice": {
      "type": "number"
    },
    "currentTick": {
      "type": "number"
    },
    "tvlUsd": {
      "type": "number"
    },
    "volume24hUsd": {
      "type": "number"
    },
    "feeApr": {
      "type": "number"
    },
    "liquidityTrend": {
      "enum": [
        "rising",
        "flat",
        "falling",
        "unknown"
      ]
    },
    "volumeTrend": {
      "enum": [
        "rising",
        "flat",
        "falling",
        "unknown"
      ]
    },
    "feeAprTrend": {
      "enum": [
        "rising",
        "flat",
        "falling",
        "unknown"
      ]
    }
  },
  "additionalProperties": true
}
